# Copy this file to .env and fill in your values

# Google Maps API Key
# Required APIs: Maps JavaScript API, Places API, Directions API
# Get your key at: https://console.cloud.google.com/apis
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Firebase VAPID Key (for Web Push / FCM notifications)
# Get from: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Generate key pair
VITE_FIREBASE_VAPID_KEY=YOUR_VAPID_KEY_HERE
